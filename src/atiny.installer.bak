#!/usr/bin/env bash
set -euo pipefail

ATINY_PREFIX="${ATINY_PREFIX:-$HOME/.atiny}"
BIN_DIR="$ATINY_PREFIX/bin"
LOG_DIR="$ATINY_PREFIX/logs"

mkdir -p "$BIN_DIR" "$LOG_DIR"

# Copy script into place
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
install -m 755 "$SCRIPT_DIR/atiny" "$BIN_DIR/atiny"

# Symlinks (your command style)
for c in ainstall finstall sinstall term fterm sterm search supdate list run start helptiny mantiny; do
  ln -sf "$BIN_DIR/atiny" "$BIN_DIR/$c"
done

# Add PATH line idempotently
ensure_path_line() {
  local rc="$1"
  local line='export PATH="$HOME/.atiny/bin:$PATH"'
  [[ -f "$rc" ]] || return 0
  grep -Fqx "$line" "$rc" && return 0
  printf "\n# ATiny\n%s\n" "$line" >> "$rc"
}

# Choose common shells
ensure_path_line "$HOME/.bashrc"
ensure_path_line "$HOME/.zshrc"
ensure_path_line "$HOME/.profile"

echo "ATiny installed to: $BIN_DIR"
echo
echo "Next step (do one):"
echo "  1) Restart your terminal"
echo "  2) Or run: export PATH=\"\$HOME/.atiny/bin:\$PATH\""
echo
echo "Test:"
echo "  helptiny"
echo "  atiny --version"
